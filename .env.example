# Supabase Auth and cloud saves. The publishable key is intentionally public;
# RLS protects every game-save row. Never add a secret/service-role key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ShiftQuest missions still work without an external AI service. Keep the
# optional server-owned provider variables below server-side; never rename
# them with a NEXT_PUBLIC_ prefix.

# Language model: mock | openai-compatible | google-gemini
# google-gemini uses native generateContent with x-goog-api-key (the same auth
# path as TTS) and defaults to gemini-3.1-flash-lite when base URL/model are blank.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_MS=20000

# Browser-supplied runtime provider credentials are accepted only for HTTPS
# origins on this comma-separated allowlist. https://api.openai.com and
# https://generativelanguage.googleapis.com are always allowed. Never add
# localhost, private-network, or IP-literal origins.
RUNTIME_PROVIDER_ALLOWED_ORIGINS=

# Neural speech: browser | openai-compatible | google-gemini
# google-gemini uses native generateContent and defaults to
# gemini-3.1-flash-tts-preview with the Kore voice when the related values are
# blank. Its raw 24 kHz mono PCM response is returned to clients as audio/wav.
# With `browser` (or incomplete provider settings), /api/tts returns browser
# SpeechSynthesis fallback metadata instead of audio.
TTS_PROVIDER=browser
TTS_API_KEY=
TTS_BASE_URL=
TTS_MODEL=
TTS_ENGLISH_VOICE=
TTS_AMERICAN_VOICE=
TTS_BRITISH_VOICE=
TTS_TURKISH_VOICE=
TTS_TIMEOUT_MS=20000

# In-process neural audio cache. Values are bounded by the server implementation.
TTS_CACHE_MAX_ITEMS=128
TTS_CACHE_TTL_SECONDS=86400
